# ════════════════════════════════════════════════════════════════
#  BiznesAI — Environment Variables (example)
#  Real .env faylini yarating va qiymatlarni o‘zgartiring.
#  BU FAYLNI GIT'GA QO‘SHING. .env faylini HECH QACHON git'ga push qilmang.
# ════════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=biznesai
POSTGRES_USER=biznesai
# MAJBURIY: kuchli parol (kamida 24 belgi, katta/kichik/raqam/belgi)
POSTGRES_PASSWORD=change_me_to_a_strong_password_24_chars_or_more

# ── JWT ─────────────────────────────────────────────────────
# MAJBURIY: kriptografik tasodifiy, kamida 32 belgi.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change_me_to_a_random_base64_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# ── Admin (ilk migratsiyada yaratiladi) ─────────────────────
ADMIN_EMAIL=biznesadmin@gmail.com
# Agar bo‘sh qoldirilsa — admin user yaratilmaydi. Production'da shart.
ADMIN_PASSWORD=

# ── Ilova ───────────────────────────────────────────────────
NODE_ENV=production
MAX_FILE_SIZE=10485760

# ── Telegram Bot (markaziy yordamchi bot) ───────────────────
# @BotFather'da /newbot orqali yarating, tokenni shu yerga qo'ying.
# Bot username (@'siz) — saytdagi deep-link uchun.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=AnalixBot

# ── Telegram MTProto (Phase 2: kanal statistika) ────────────
# my.telegram.org dan oling. Bot uchun emas, GramJS user-account login uchun.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session shifrlash kaliti (32 baytli base64) — bir marta generatsiya:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TELEGRAM_SESSION_ENC_KEY=
